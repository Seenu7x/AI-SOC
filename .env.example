# ─── AI-SOC Production Environment ───────────────────────────────────────────
# Copy this file to .env and fill in real values before running deploy.sh
# NEVER commit .env to version control!

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aisoc:CHANGE_DB_PASSWORD@localhost:5432/aisoc_db
DB_PASSWORD=CHANGE_DB_PASSWORD

# ── API Settings ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# ── Auth Secrets (generate with: openssl rand -hex 32) ───────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ANALYST_PASSWORD=CHANGE_ME_strong_analyst_password

# API key for internal log-agent ↔ backend communication
API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_24

# Token expiry (seconds × 60 = minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ML Model Settings ────────────────────────────────────────────────────────
MODEL_PATH=./models
MIN_TRAINING_SAMPLES=100
ANOMALY_THRESHOLD=-0.5
CONTAMINATION_RATE=0.01

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/aisoc.log

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=aisoc-redis-pass
REDIS_URL=redis://:aisoc-redis-pass@redis:6379/0

# ── Monitoring ───────────────────────────────────────────────────────────────
ENABLE_METRICS=True
